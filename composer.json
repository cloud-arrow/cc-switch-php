{
    "name": "cc-switch/cc-switch-php",
    "description": "CLI + Web UI manager for Claude Code, Codex, Gemini CLI, OpenCode & OpenClaw",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "ext-swoole": ">=5.0",
        "ext-pdo_sqlite": "*",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0",
        "symfony/validator": "^7.0",
        "yosymfony/toml": "^1.0",
        "nikic/fast-route": "^1.3",
        "guzzlehttp/guzzle": "^7.0",
        "ramsey/uuid": "^4.0",
        "catfan/medoo": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "CcSwitch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CcSwitch\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/cc-switch"]
}
